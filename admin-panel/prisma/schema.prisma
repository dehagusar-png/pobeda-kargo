generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique
  phone      String?  @unique
  firstName  String?
  lastName   String?
  language   String   @default("tg") // tg, ru, uz, zh
  clientCode String?  @unique // PB-XXXX
  role       Role     @default(USER) // USER, ADMIN, WORKER
  password   String?
  parcels    Parcel[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Parcel {
  id        Int          @id @default(autoincrement())
  trackCode String       @unique
  weight    Float?
  volume    Float?
  price     Float?
  status    ParcelStatus @default(EXPECTED)
  userId    Int?
  user      User?        @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Settings {
  id           Int      @id @default(1)
  exchangeRate Float    @default(1.50) // CNY to TJS rate (includes margin)
  pricingData  Json?
  updatedAt    DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
  WORKER
  SUPERADMIN
}

enum ParcelStatus {
  EXPECTED
  IN_CHINA
  IN_TRANSIT
  ARRIVED
  DELIVERED
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  adminName  String
  action     String
  target     String
  details    String?
  createdAt  DateTime @default(now())
}
